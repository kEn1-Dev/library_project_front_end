---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "UniShare - Academic Resource Forum & Digital Community Library" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-slate-50/50 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(99,102,241,0.05),rgba(255,255,255,0))]">
    <slot />
  </body>
</html>
