---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
---

<Layout title="UniShare - Academic Forum & Biblioteca Digital">
  <!-- Navigation Header -->
  <Navbar client:load />

  <!-- Main Content Wrapper -->
  <main class="flex-1">
    
    <!-- Hero Section -->
    <section class="py-20 flex items-center bg-[radial-gradient(circle_at_90%_10%,rgba(99,102,241,0.05)_0%,transparent_60%)]">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-12 items-center gap-16 w-full">
        <div class="md:col-span-7 flex flex-col items-start animate-fade-in">
          <span class="bg-indigo-50 border border-indigo-100 text-brand-navy text-[10px] font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">
            Centro Académico Digital
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-slate-800 tracking-tight leading-[1.08] mb-6">
            Comparte <span class="bg-gradient-text bg-clip-text text-transparent">Conocimiento</span>,<br />Conecta Estudiantes.
          </h1>
          <p class="text-base md:text-lg text-slate-400 font-medium max-w-xl leading-relaxed mb-10">
            UniShare es la plataforma moderna y minimalista diseñada para que estudiantes y docentes compartan recursos académicos, libros y material de estudio de forma libre y colaborativa.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
            <a href="/register" class="px-6 py-3.5 text-sm font-bold rounded-full bg-gradient-brand text-white shadow-brand hover:opacity-95 hover:-translate-y-px transition-all btn-transition text-center">
              Comenzar Gratis
            </a>
            <a href="/login" class="px-6 py-3.5 text-sm font-bold rounded-full border border-slate-200 text-slate-700 hover:bg-slate-50 transition-all btn-transition text-center">
              Iniciar Sesión
            </a>
          </div>
        </div>
        
        <div class="md:col-span-5 flex justify-center items-center animate-fade-in">
          <div class="bg-white border border-slate-200 rounded-[32px] p-12 shadow-brand shadow-slate-100 max-w-[340px] w-full aspect-square flex items-center justify-center animate-float">
            <img src="/logo.svg" alt="UniShare Animated Logo" class="w-full h-auto" />
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="bg-white border-y border-slate-200 py-12">
      <div class="max-w-7xl mx-auto px-6 flex flex-col sm:flex-row justify-around items-center gap-8">
        <div class="text-center flex flex-col gap-2">
          <h3 class="text-4xl font-extrabold bg-gradient-text bg-clip-text text-transparent">15K+</h3>
          <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Descargas Realizadas</p>
        </div>
        <div class="hidden sm:block w-px h-12 bg-slate-200"></div>
        <div class="text-center flex flex-col gap-2">
          <h3 class="text-4xl font-extrabold bg-gradient-text bg-clip-text text-transparent">2,400+</h3>
          <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Recursos Compartidos</p>
        </div>
        <div class="hidden sm:block w-px h-12 bg-slate-200"></div>
        <div class="text-center flex flex-col gap-2">
          <h3 class="text-4xl font-extrabold bg-gradient-text bg-clip-text text-transparent">1,200+</h3>
          <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Estudiantes Activos</p>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-24 bg-[radial-gradient(circle_at_10%_90%,rgba(236,72,153,0.02)_0%,transparent_60%)]">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-black text-slate-800 tracking-tight mb-4">¿Por qué usar UniShare?</h2>
          <p class="text-sm text-slate-400 font-semibold max-w-md mx-auto leading-relaxed">
            Una experiencia optimizada, minimalista y diseñada especialmente para la vida académica.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white border border-slate-200 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg hover:border-slate-300 transition-all duration-300 shadow-sm">
            <div class="w-12 h-12 rounded-xl bg-indigo-50 flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"></path><path d="M6 6h10"></path><path d="M6 10h10"></path></svg>
            </div>
            <h3 class="text-lg font-extrabold text-slate-800 mb-3">Biblioteca Abierta</h3>
            <p class="text-slate-400 font-semibold text-sm leading-relaxed">
              Accede a libros, apuntes de clases, guías de estudio y exámenes ordenados por categorías específicas.
            </p>
          </div>

          <div class="bg-white border border-slate-200 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg hover:border-slate-300 transition-all duration-300 shadow-sm">
            <div class="w-12 h-12 rounded-xl bg-pink-50 flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-pink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
            </div>
            <h3 class="text-lg font-extrabold text-slate-800 mb-3">Compartir Directo</h3>
            <p class="text-slate-400 font-semibold text-sm leading-relaxed">
              ¿Tienes buen material? Súbelo de forma rápida integrándolo directamente a la base de datos de la comunidad.
            </p>
          </div>

          <div class="bg-white border border-slate-200 rounded-2xl p-8 hover:-translate-y-1 hover:shadow-lg hover:border-slate-300 transition-all duration-300 shadow-sm">
            <div class="w-12 h-12 rounded-xl bg-purple-50 flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-brand-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <h3 class="text-lg font-extrabold text-slate-800 mb-3">Métricas en Tiempo Real</h3>
            <p class="text-slate-400 font-semibold text-sm leading-relaxed">
              Lleva el registro de las descargas y visualiza estadísticas de tus recursos subidos en tiempo real.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action Banner -->
    <section class="pb-24">
      <div class="max-w-7xl mx-auto px-6">
        <div class="bg-gradient-brand rounded-[32px] py-16 px-8 text-center shadow-brand shadow-indigo-100 flex flex-col items-center justify-center">
          <h2 class="text-3xl md:text-4xl font-black text-white tracking-tight mb-4">¿Listo para unirte a la red?</h2>
          <p class="text-indigo-100 text-sm md:text-base max-w-md mb-8 leading-relaxed font-semibold">
            Comienza a descargar, visualizar y organizar todo tu material académico en un solo lugar.
          </p>
          <a href="/register" class="px-8 py-4 text-sm font-extrabold rounded-full bg-white text-brand-navy hover:bg-slate-50 shadow-md hover:-translate-y-px transition-all btn-transition">
            Crear Cuenta Gratis
          </a>
        </div>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <Footer />
</Layout>
